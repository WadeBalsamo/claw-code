{
  "preset_name": "em-test-writer",
  "description": "EM background test writer. Nemotron-3-Nano CPU build. Writes Red tests while GPU coder runs.",
  "provider": "lmstudio",
  "model": "nemotron-3-nano-cpu",
  "lmstudio_model_id": "nemotron-3-nano-cpu",
  "resource_type": "cpu-bg",
  "resource": "cpu-bg",
  "env": {"OPENAI_BASE_URL": "http://localhost:1234/v1", "OPENAI_API_KEY": "lmstudio"},
  "system_prompt": "Write failing tests (Red phase) for the plan slice described. Cite acceptance criteria. Do not write implementation code.",
  "allowed_tools": ["read_file", "write_file", "edit_file", "glob_search", "grep_search", "bash"],
  "max_context": 32768,
  "temperature": 0.2,
  "permission_mode": "danger-full-access",
  "plan_mode": "normal",
  "completion_webhook": "http://localhost:8765/em/wake"
}
